# birdnet-collage-eink
# Production Pi: set DISPLAY_DRIVER=inky_impression, CACHE_DIR=/var/lib/birdnet-eink
COLLAGE_URL=http://birdnet-collage:8081
DISPLAY_DRIVER=simulator
DISPLAY_WIDTH=1600
DISPLAY_HEIGHT=1200
POLL_INTERVAL=300
LOOKBACK_HOURS=24
CACHE_DIR=/tmp/birdnet-eink
LOG_LEVEL=INFO
SIMULATOR_OUTDIR=/tmp/eink-sim
FORCE_REFRESH=0
SATURATION=0.5
# Physical buttons (0=off, 1=on; requires gpiod + gpiodevice on Pi)
BUTTONS_ENABLED=0

# Diagnostics endpoint (0 to disable)
DIAGNOSTICS_PORT=8082

# Pi deployment (copy to .env and fill in)
PI_USER=pi
PI_HOST=birdnet-pi.local